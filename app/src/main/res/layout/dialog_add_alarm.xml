<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TimePicker -->
        <TimePicker
            android:id="@+id/time_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:timePickerMode="spinner"
            android:textColor="@color/white"/>

        <!-- Đường kẻ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="12dp"/>

        <!-- Nhãn -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhãn"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <EditText
            android:id="@+id/et_alarm_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập tên báo thức..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/white"
            android:backgroundTint="@color/accent_purple"
            android:layout_marginBottom="16dp"/>

        <!-- Đường kẻ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp"/>

        <!-- Nhạc chuông -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                android:tint="@color/accent_purple"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhạc chuông"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:layout_weight="1"/>

        </LinearLayout>

        <!-- Chọn loại nhạc chuông -->
        <RadioGroup
            android:id="@+id/rg_ringtone_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="34dp"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/rb_ringtone_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhạc chuông mặc định"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_ringtone_device"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn từ thiết bị..."
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"/>

        </RadioGroup>

        <!-- Hiển thị tên nhạc đã chọn -->
        <TextView
            android:id="@+id/tv_selected_ringtone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhạc chuông mặc định"
            android:textColor="@color/accent_purple"
            android:textSize="13sp"
            android:layout_marginStart="34dp"
            android:layout_marginBottom="16dp"/>

        <!-- Đường kẻ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp"/>

        <!-- Rung -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="@color/accent_purple"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rung"
                android:textColor="@color/white"
                android:textSize="15sp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_vibrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/white"
                app:trackTint="@color/accent_purple"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

        </LinearLayout>

        <!-- Đường kẻ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp"/>

        <!-- Lặp lại -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="@color/accent_purple"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lặp lại"
                android:textColor="@color/white"
                android:textSize="15sp"/>

        </LinearLayout>

        <!-- Chọn ngày lặp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="34dp"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/cb_mon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T2"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:textSize="12sp"/>

            <CheckBox
                android:id="@+id/cb_tue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T3"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:textSize="12sp"/>

            <CheckBox
                android:id="@+id/cb_wed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T4"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:textSize="12sp"/>

            <CheckBox
                android:id="@+id/cb_thu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T5"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:textSize="12sp"/>

            <CheckBox
                android:id="@+id/cb_fri"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T6"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:textSize="12sp"/>

            <CheckBox
                android:id="@+id/cb_sat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T7"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:textSize="12sp"/>

            <CheckBox
                android:id="@+id/cb_sun"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CN"
                android:textColor="@color/white"
                android:buttonTint="@color/accent_purple"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>