<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/black"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back_city"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thêm thành phố"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:paddingStart="8dp"/>

        <!-- Nút tìm kiếm -->
        <ImageButton
            android:id="@+id/btn_search_toggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"/>

    </LinearLayout>

    <!-- Thanh tìm kiếm (ẩn mặc định) -->
    <EditText
        android:id="@+id/et_search_city"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Tìm thành phố..."
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/white"
        android:background="#FF2A2A2A"
        android:paddingHorizontal="16dp"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:visibility="gone"/>

    <!-- Danh sách kết quả tìm kiếm (ẩn mặc định) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:background="@color/black"
        android:visibility="gone"/>

    <!-- Bản đồ -->
    <fragment
        android:id="@+id/map_picker"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>