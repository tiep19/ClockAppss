<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ClockApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:editTextColor">@color/white</item>
        <item name="alertDialogTheme">@style/DarkDialog</item>
    </style>

    <!-- Style riêng cho NumberPicker để chữ trắng -->
    <style name="WhiteNumberPicker">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Style cho Dialog nền tối -->
    <style name="DarkDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:background">@color/surface_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
    </style>
</resources>